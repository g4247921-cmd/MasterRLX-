-- Fungsi Avatar Anti-Bug
local function GetUserHeadshot(userId, imageLabel)
    coroutine.wrap(function()
        local maxTries, tries, content, isReady = 5, 0, nil, false
        repeat
            tries = tries + 1
            pcall(function()
                content, isReady = Players:GetUserThumbnailAsync(userId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
            end)
            if isReady then break end
            task.wait(0.4)
        until tries >= maxTries
        if imageLabel and imageLabel.Parent then
            imageLabel.Image = isReady and content or "rbxassetid://6074241743"
        end
    end)()
end

-- State Management
local currentViewedPlayer = nil
local activeConnections = {}

-- Fungsi mengembalikan kamera ke diri sendiri secara aman
local function ResetCamera()
    currentViewedPlayer = nil
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        WorkspaceCamera.CameraSubject = humanoid
    else
        WorkspaceCamera.CameraSubject = character
    end
end

CloseBtn.MouseButton1Click:Connect(function()
    ResetCamera()
    -- Putus semua koneksi loop render jarak agar tidak memory leak
    for _, conn in pairs(activeConnections) do
        if conn then conn:Disconnect() end
    end
    ScreenGui:Destroy()
end)

-- Fungsi Inti Refresh UI List Player
local function RefreshList(filterText)
    filterText = filterText or ""
    
    -- Putus koneksi render jarak yang lama sebelum membersihkan list
    for _, conn in pairs(activeConnections) do
        if conn then conn:Disconnect() end
    end
    activeConnections = {}

    for _, item in pairs(PlayerList:GetChildren()) do
        if item:IsA("Frame") then item:Destroy() end
    end

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local nameLower = string.lower(player.Name)
            local displayLower = string.lower(player.DisplayName)
            local filterLower = string.lower(filterText)
            
            local matchName = string.find(nameLower, filterLower)
            local matchDisplay = string.find(displayLower, filterLower)
            
            if filterText == "" or matchName or matchDisplay then
                
                -- Player Card
                local Card = Instance.new("Frame")
                Card.Size = UDim2.new(1, -4, 0, 45)
                Card.BackgroundColor3 = Color3.fromRGB(22, 22, 28)
                Card.BorderSizePixel = 0
                Card.Parent = PlayerList
                Instance.new("UICorner", Card).CornerRadius = UDim.new(0, 8)
                
                -- Avatar Frame
                local AvaFrame = Instance.new("Frame")
                AvaFrame.Size = UDim2.new(0, 34, 0, 34)
                AvaFrame.Position = UDim2.new(0, 6, 0.5, -17)
                AvaFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 38)
                AvaFrame.Parent = Card
                Instance.new("UICorner", AvaFrame).CornerRadius = UDim.new(1, 0)
                
                local AvaImage = Instance.new("ImageLabel")
                AvaImage.Size = UDim2.new(1, 0, 1, 0)
                AvaImage.BackgroundTransparency = 1
                AvaImage.Parent = AvaFrame
                Instance.new("UICorner", AvaImage).CornerRadius = UDim.new(1, 0)
                GetUserHeadshot(player.UserId, AvaImage)

                -- Teks Info Player
                local InfoLabel = Instance.new("TextLabel")
                InfoLabel.Size = UDim2.new(0.45, 0, 1, 0)
                InfoLabel.Position = UDim2.new(0, 46, 0, 0)
                InfoLabel.BackgroundTransparency = 1
                InfoLabel.RichText = true
                InfoLabel.Text = "<font color='rgb(255,255,255)'><b>" .. player.DisplayName .. "</b></font><br/><font color='rgb(140,140,150)'>@" .. player.Name .. "</font>"
                InfoLabel.Font = Enum.Font.GothamMedium
                InfoLabel.TextSize = 10
                InfoLabel.TextXAlignment = Enum.TextXAlignment.Left
                InfoLabel.Parent = Card

                -- Indikator Jarak Real-time
                local DistanceLabel = Instance.new("TextLabel")
                DistanceLabel.Size = UDim2.new(0.2, 0, 1, 0)
                DistanceLabel.Position = UDim2.new(1, -145, 0, 0)
                DistanceLabel.BackgroundTransparency = 1
                DistanceLabel.RichText = true
                DistanceLabel.Font = Enum.Font.GothamBold
                DistanceLabel.TextSize = 9
                DistanceLabel.TextXAlignment = Enum.TextXAlignment.Right
                DistanceLabel.Parent = Card
                
                local distConnection
                distConnection = RunService.RenderStepped:Connect(function()
                    if not Card or not Card.Parent then 
                        distConnection:Disconnect() 
                        return 
                    end
                    local myChar = LocalPlayer.Character
                    local pChar = player.Character
                    if pChar and pChar:FindFirstChild("HumanoidRootPart") and myChar and myChar:FindFirstChild("HumanoidRootPart") then
                        local distance = (myChar.HumanoidRootPart.Position - pChar.HumanoidRootPart.Position).Magnitude
                        DistanceLabel.Text = "<font color='rgb(212,175,55)'>" .. string.format("%.0f", distance) .. "</font><font color='rgb(100,100,110)'>m</font>"
                    else
                        DistanceLabel.Text = "<font color='rgb(255,75,75)'>Dead</font>"
                    end
                end)
                table.insert(activeConnections, distConnection)

                -- Tombol VIEW CAMERA
                local ViewBtn = Instance.new("TextButton")
                ViewBtn.Size = UDim2.new(0, 42, 0, 24)
                ViewBtn.Position = UDim2.new(1, -92, 0.5, -12)
                ViewBtn.Font = Enum.Font.GothamBold
                ViewBtn.TextSize = 9
                ViewBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
                ViewBtn.Parent = Card
                Instance.new("UICorner", ViewBtn).CornerRadius = UDim.new(0, 6)

                if currentViewedPlayer == player then
                    ViewBtn.Text = "UNVIEW"
                    ViewBtn.BackgroundColor3 = Color3.fromRGB(255, 75, 75)
                else
                    ViewBtn.Text = "VIEW"
                    ViewBtn.BackgroundColor3 = Color3.fromRGB(0, 128, 255)
                end

                -- Tombol TELEPORT (Bypass Jarak Jauh)
                local TpBtn = Instance.new("TextButton")
                TpBtn.Size = UDim2.new(0, 38, 0, 24)
                TpBtn.Position = UDim2.new(1, -44, 0.5, -12)
                TpBtn.BackgroundColor3 = Color3.fromRGB(212, 175, 55)
                TpBtn.Text = (currentViewedPlayer == player) and "HERE" or "TP"
                TpBtn.Font = Enum.Font.GothamBold
                TpBtn.TextSize = 9
                TpBtn.TextColor3 = Color3.fromRGB(15, 15, 20)
                TpBtn.Parent = Card
                Instance.new("UICorner", TpBtn).CornerRadius = UDim.new(0, 6)

                -- Logika Klik VIEW CAMERA
                ViewBtn.MouseButton1Click:Connect(function()
                    if currentViewedPlayer == player then
                        ResetCamera()
                    else
                        local pChar = player.Character
                        if pChar and pChar:FindFirstChildOfClass("Humanoid") then
                            currentViewedPlayer = player
                            WorkspaceCamera.CameraSubject = pChar:FindFirstChildOfClass("Humanoid")
                        end
                    end
                    RefreshList(SearchBox.Text)
                end)

                -- Logika Klik TELEPORT (Dioptimalkan untuk Jarak Sangat Jauh & Anti-Gagal)
                TpBtn.MouseButton1Click:Connect(function()
                    local myChar = LocalPlayer.Character
                    local pChar = player.Character
                    
                    if myChar and pChar then
                        local myHRP = myChar:FindFirstChild("HumanoidRootPart")
                        local pHRP = pChar:FindFirstChild("HumanoidRootPart")
                        local myHum = myChar:FindFirstChildOfClass("Humanoid")
                        
                        if myHRP and pHRP and myHum and myHum.Health > 0 then
                            -- Pengaman: Matikan velocity instan agar tidak mental saat teleportasi jarak sangat jauh
                            myHRP.Velocity = Vector3.new(0,0,0)
                            myHRP.RotVelocity = Vector3.new(0,0,0)
                            
                            -- Proses Teleportasi ke target (+2 koor Y agar tidak amblas ke tanah)
                            myHRP.CFrame = pHRP.CFrame * CFrame.new(0, 2, 0)
                        end
                    end
                end)
            end
        end
    end
    PlayerList.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y + 10)
end

-- Perbaikan Sistem Loop Proteksi Kamera (Auto Detect Terkunci & Valid)
RunService.Heartbeat:Connect(function()
    if currentViewedPlayer then
        local target = currentViewedPlayer
        local char = target.Character
        
        -- Deteksi jika Target Keluar, Mati, atau Ganti Karakter
        if not target.Parent or not char or not char:FindFirstChildOfClass("Humanoid") or char:FindFirstChildOfClass("Humanoid").Health <= 0 then
            ResetCamera()
            RefreshList(SearchBox.Text)
        else
            -- Pastikan Kamera Selalu Mengunci Humanoid Target Secara Realtime
            local targetHum = char:FindFirstChildOfClass("Humanoid")
            if targetHum and WorkspaceCamera.CameraSubject ~= targetHum then
                WorkspaceCamera.CameraSubject = targetHum
            end
        end
    end
end)

