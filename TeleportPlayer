-- FUNGSI MEMBUAT TEXT AUTO-SCALE RAPI (Mencegah font terlalu besar/kecah)
local function ApplyTextScale(textLabel, min, max)
    textLabel.TextScaled = true
    local constraint = Instance.new("UITextSizeConstraint")
    constraint.MinTextSize = min or 8
    constraint.MaxTextSize = max or 14
    constraint.Parent = textLabel
end

-- SISTEM NOTIFIKASI MEWAH (Auto-Scale & Rapih)
local function Notify(msg)
    local NotifFrame = Instance.new("Frame")
    NotifFrame.Size = UDim2.new(0, 220, 0, 40)
    NotifFrame.Position = UDim2.new(1, 10, 0, 20)
    NotifFrame.BackgroundColor3 = Color3.fromRGB(22, 22, 28)
    NotifFrame.BackgroundTransparency = 0.1
    NotifFrame.Parent = ScreenGui
    
    local NotifCorner = Instance.new("UICorner")
    NotifCorner.CornerRadius = UDim.new(0, 8)
    NotifCorner.Parent = NotifFrame
    
    local NotifStroke = Instance.new("UIStroke")
    NotifStroke.Thickness = 1
    NotifStroke.Color = Color3.fromRGB(212, 175, 55)
    NotifStroke.Parent = NotifFrame
    
    local NotifText = Instance.new("TextLabel")
    NotifText.Size = UDim2.new(1, -20, 1, -10)
    NotifText.Position = UDim2.new(0, 10, 0, 5)
    NotifText.BackgroundTransparency = 1
    NotifText.Text = msg
    NotifText.TextColor3 = Color3.fromRGB(255, 255, 255)
    NotifText.Font = Enum.Font.GothamBold
    NotifText.TextXAlignment = Enum.TextXAlignment.Center
    NotifText.Parent = NotifFrame
    ApplyTextScale(NotifText, 9, 12)
    
    TweenService:Create(NotifFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(1, -240, 0, 20)}):Play()
    
    task.delay(2.5, function()
        local tween = TweenService:Create(NotifFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position = UDim2.new(1, 10, 0, 20)})
        tween:Play()
        tween.Completed:Connect(function()
            NotifFrame:Destroy()
        end)
    end)
end

