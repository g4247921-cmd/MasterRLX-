-- Fungsi Avatar Headshot (Thread Safe & Cepat)
local function GetUserHeadshot(userId, imageLabel)
    task.spawn(function()
        local content, isReady = nil, false
        pcall(function()
            content, isReady = Players:GetUserThumbnailAsync(userId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
        end)
        if isReady and content then
            imageLabel.Image = content
        else
            imageLabel.Image = "rbxassetid://6074241743"
        end
    end)
end

local currentViewedPlayer = nil

-- Fungsi Inti Refresh UI List Player
local function RefreshList(filterText)
    filterText = filterText or ""
    
    for _, item in pairs(PlayerList:GetChildren()) do
        if item:IsA("Frame") then item:Destroy() end
    end

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local matchName = string.find(string.lower(player.Name), string.lower(filterText))
            local matchDisplay = string.find(string.lower(player.DisplayName), string.lower(filterText))
            
            if filterText == "" or matchName or matchDisplay then
                
                -- Player Card
                local Card = Instance.new("Frame")
                Card.Size = UDim2.new(1, -4, 0, 45)
                Card.BackgroundColor3 = Color3.fromRGB(22, 22, 28)
                Card.BackgroundTransparency = 0.2
                Card.BorderSizePixel = 0
                Card.Parent = PlayerList
                Instance.new("UICorner", Card).CornerRadius = UDim.new(0, 8)
                
                -- Avatar Frame
                local AvaFrame = Instance.new("Frame")
                AvaFrame.Size = UDim2.new(0, 34, 0, 34)
                AvaFrame.Position = UDim2.new(0, 6, 0.5, -17)
                AvaFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 38)
                AvaFrame.Parent = Card
                Instance.new("UICorner", AvaFrame).CornerRadius = UDim.new(1, 0)
                
                local AvaImage = Instance.new("ImageLabel")
                AvaImage.Size = UDim2.new(1, 0, 1, 0)
                AvaImage.BackgroundTransparency = 1
                AvaImage.Parent = AvaFrame
                Instance.new("UICorner", AvaImage).CornerRadius = UDim.new(1, 0)
                GetUserHeadshot(player.UserId, AvaImage)

                -- Teks Info Player (Diatur sizenya agar pas & presisi)
                local InfoLabel = Instance.new("TextLabel")
                InfoLabel.Size = UDim2.new(0.4, 0, 0.8, 0)
                InfoLabel.Position = UDim2.new(0, 46, 0.1, 0)
                InfoLabel.BackgroundTransparency = 1
                InfoLabel.RichText = true
                InfoLabel.Text = "<font color='rgb(255,255,255)'><b>" .. player.DisplayName .. "</b></font><br/><font color='rgb(140,140,150)'>@" .. player.Name .. "</font>"
                InfoLabel.Font = Enum.Font.GothamMedium
                InfoLabel.TextXAlignment = Enum.TextXAlignment.Left
                InfoLabel.Parent = Card
                ApplyTextScale(InfoLabel, 8, 11)

                -- Indikator Jarak Real-time
                local DistanceLabel = Instance.new("TextLabel")
                DistanceLabel.Size = UDim2.new(0.18, 0, 0.5, 0)
                DistanceLabel.Position = UDim2.new(1, -145, 0.25, 0)
                DistanceLabel.BackgroundTransparency = 1
                DistanceLabel.RichText = true
                DistanceLabel.Font = Enum.Font.GothamBold
                DistanceLabel.TextXAlignment = Enum.TextXAlignment.Right
                DistanceLabel.Parent = Card
                ApplyTextScale(DistanceLabel, 8, 10)
                
                local distConnection
                distConnection = RunService.RenderStepped:Connect(function()
                    if not Card or not Card.Parent then distConnection:Disconnect() return end
                    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                        local distance = (LocalPlayer.Character.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
                        DistanceLabel.Text = "<font color='rgb(212,175,55)'>" .. string.format("%.0f", distance) .. "</font><font color='rgb(100,100,110)'>m</font>"
                    else
                        DistanceLabel.Text = "<font color='rgb(255,75,75)'>Dead</font>"
                    end
                end)

                -- Tombol VIEW CAMERA (Spy)
                local ViewBtn = Instance.new("TextButton")
                ViewBtn.Size = UDim2.new(0, 42, 0, 24)
                ViewBtn.Position = UDim2.new(1, -92, 0.5, -12)
                ViewBtn.BackgroundColor3 = Color3.fromRGB(0, 128, 255)
                ViewBtn.Font = Enum.Font.GothamBold
                ViewBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
                ViewBtn.Parent = Card
                Instance.new("UICorner", ViewBtn).CornerRadius = UDim.new(0, 6)
                ApplyTextScale(ViewBtn, 7, 9)

                if currentViewedPlayer == player then
                    ViewBtn.Text = "UNVIEW"
                    ViewBtn.BackgroundColor3 = Color3.fromRGB(255, 75, 75)
                else
                    ViewBtn.Text = "VIEW"
                    ViewBtn.BackgroundColor3 = Color3.fromRGB(0, 128, 255)
                end

                -- Tombol TELEPORT (TP)
                local TpBtn = Instance.new("TextButton")
                TpBtn.Size = UDim2.new(0, 38, 0, 24)
                TpBtn.Position = UDim2.new(1, -44, 0.5, -12)
                TpBtn.BackgroundColor3 = Color3.fromRGB(212, 175, 55)
                TpBtn.Text = (currentViewedPlayer == player) and "HERE" or "TP"
                TpBtn.Font = Enum.Font.GothamBold
                TpBtn.TextColor3 = Color3.fromRGB(15, 15, 20)
                TpBtn.Parent = Card
                Instance.new("UICorner", TpBtn).CornerRadius = UDim.new(0, 6)
                ApplyTextScale(TpBtn, 7, 9)

                -- Logika VIEW CAMERA
                ViewBtn.MouseButton1Click:Connect(function()
                    if currentViewedPlayer == player then
                        currentViewedPlayer = nil
                        local myHumanoid = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
                        WorkspaceCamera.CameraSubject = myHumanoid or LocalPlayer.Character
                        Notify("Kamera kembali ke kamu")
                    else
                        if player.Character and player.Character:FindFirstChildOfClass("Humanoid") then
                            currentViewedPlayer = player
                            WorkspaceCamera.CameraSubject = player.Character:FindFirstChildOfClass("Humanoid")
                            Notify("Mengintip: " .. player.DisplayName)
                        end
                    end
                    RefreshList(SearchBox.Text)
                end)

                -- Logika TELEPORT
                TpBtn.MouseButton1Click:Connect(function()
                    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                        LocalPlayer.Character.HumanoidRootPart.CFrame = player.Character.HumanoidRootPart.CFrame * CFrame.new(0, 2, 0)
                        Notify("Teleport ke " .. player.DisplayName)
                    end
                end)
            end
        end
    end
    PlayerList.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y + 10)
end

-- Sistem Loop Proteksi Kamera
RunService.Heartbeat:Connect(function()
    if currentViewedPlayer then
        if not currentViewedPlayer.Parent or not currentViewedPlayer.Character or not currentViewedPlayer.Character:FindFirstChildOfClass("Humanoid") or currentViewedPlayer.Character:FindFirstChildOfClass("Humanoid").Health <= 0 then
            currentViewedPlayer = nil
            local myHumanoid = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            WorkspaceCamera.CameraSubject = myHumanoid or LocalPlayer.Character
            Notify("Target Mati / Keluar server")
            RefreshList(SearchBox.Text)
        else
            if WorkspaceCamera.CameraSubject ~= currentViewedPlayer.Character:FindFirstChildOfClass("Humanoid") then
                WorkspaceCamera.CameraSubject = currentViewedPlayer.Character:FindFirstChildOfClass("Humanoid")
            end
        end
    end
end)

-- Listener Event Input & Player Update
SearchBox:GetPropertyChangedSignal("Text"):Connect(function() RefreshList(SearchBox.Text) end)
Players.PlayerAdded:Connect(function(p) 
    Notify(p.DisplayName .. " Join Server")
    RefreshList(SearchBox.Text) 
end)
Players.PlayerRemoving:Connect(function(p) 
    Notify(p.DisplayName .. " Leave Server")
    if currentViewedPlayer == p then
        currentViewedPlayer = nil
        local myHumanoid = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        WorkspaceCamera.CameraSubject = myHumanoid or LocalPlayer.Character
    end
    RefreshList(SearchBox.Text) 
end)

-- Jalankan Pertama Kali
RefreshList()
