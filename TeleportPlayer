-- Otomatis Refresh list jika ada player yang Respawn agar datanya update
Players.PlayerLoop = task.spawn(function()
    while task.wait(2) do
        if ScreenGui and ScreenGui.Parent then
            -- Hanya update list jika tidak sedang mengetik agar tidak mengganggu search box
            if SearchBox.Text == "" then
                RefreshList("")
            end
        else
            break
        end
    end
end)

